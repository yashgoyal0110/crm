# AtlasIQ public reverse proxy.
#
# Caddy listens on public HTTP port 80 and proxies to the Docker app on host
# port 3002. Match PUBLIC_APP_URL in .env exactly:
#   PUBLIC_APP_URL=http://8.229.88.229

http://8.229.88.229 {
	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	reverse_proxy 127.0.0.1:3002
}
