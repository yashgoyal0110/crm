# DistIQ public reverse proxy.
#
# Caddy serves public HTTPS and proxies to the Docker app on host port 3002.
# Match PUBLIC_APP_URL in .env exactly:
#   PUBLIC_APP_URL=https://distiq.8.229.88.229.sslip.io

https://distiq.8.229.88.229.sslip.io {
	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	reverse_proxy 127.0.0.1:3002 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Port 443
	}
}

servicedock.8.229.88.229.sslip.io {
  reverse_proxy 127.0.0.1:4001
}
